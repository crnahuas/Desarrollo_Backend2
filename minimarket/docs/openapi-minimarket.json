              "example": {
                "usuario": {
                  "id": 1
                },
                "producto": {
                  "id": 1
                },
                "cantidad": 3
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Item del carrito actualizado correctamente",
